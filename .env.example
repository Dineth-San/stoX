# stoX ML Pipeline — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── FRED API ───────────────────────────────────────────────────────────────────
# Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── MLflow ─────────────────────────────────────────────────────────────────────
# Leave blank to use the default local file store (ml/mlruns)
MLFLOW_TRACKING_URI=

# ── DVC remote (optional — only needed if using cloud storage) ─────────────────
DVC_REMOTE_URL=

# ── News ingestion ─────────────────────────────────────────────────────────────
# Optional: NewsAPI key for fallback news source (https://newsapi.org)
NEWS_API_KEY=
